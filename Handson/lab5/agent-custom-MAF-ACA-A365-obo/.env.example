# agent-custom-MAF-ACA-A365-obo 用 .env（例）
# lab3 / lab4 の Agent ID 出口化版（egress）と同一の接続情報に、OBO（ユーザー委任型）の設定を加えた版。
# ACA 実行時は deploy-aca.ps1 が同じキーを Container App の環境変数として設定します。

AZURE_TENANT_ID=655bd66a-5001-4cb3-9aad-ce54a27d5d95
AZURE_SUBSCRIPTION_ID=
# ACA をデプロイするリージョン
AZURE_LOCATION=eastus2

# 既存 Foundry プロジェクト（ms-foundry-observability でデプロイ）
# APIM 経由化後は未使用。切り戻し用に残す。
PROJECT_ENDPOINT=
MODEL_DEPLOYMENT_NAME=
# 任意: エージェント専用モデルを使う場合に上書き（未設定なら MODEL_DEPLOYMENT_NAME）
AGENT_MODEL_DEPLOYMENT_NAME=

# LLM: APIM AI Gateway 経由（apim-aigateway-eastus2）
#   OpenAIChatCompletionClient(azure_endpoint=...) には path=openai までを含むベース URL を渡す。
#   出口（UAMI または Agent ID）が cognitiveservices の token を取得し、APIM が
#   validate-azure-ad-token で検証する。
APIM_AOAI_ENDPOINT=https://apim-aigateway-eastus2.azure-api.net/openai
APIM_AOAI_DEPLOYMENT=gpt-5.4
APIM_AOAI_API_VERSION=2024-10-21
# 別 audience に切り替える場合のみ設定（例: api://<apim-app-id>/.default）
APIM_SCOPE=

# 可観測性（OTel トレースを App Insights に送信、任意）
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPLICATIONINSIGHTS_NAME=

# Contoso ポリシー MCP（任意。設定すると MCP ツールを構成）
# APIM 経由（contoso-policy/mcp）。APIM が backend へ x-contoso-key を付与して中継する。
CONTOSO_MCP_URL=https://apim-aigateway-eastus2.azure-api.net/contoso-policy/mcp
# 既定（空）では APIM_SCOPE と同じ scope（cognitiveservices）を共有する。別 audience の場合のみ設定。
MCP_RESOURCE_APP_ID=
MCP_SCOPE=
# APIM 経由化後は通常不要。直接 backend に当てる切り戻し用としてのみ残す。
CONTOSO_MCP_KEY=

# ---------------------------------------------------------------------------
# Agent ID 出口化（fmi_path 2 ステップ交換）— 自律型 Step 2a / OBO Step 2b で共有
# ---------------------------------------------------------------------------
# true で LLM / MCP の出口トークンを UAMI ではなく Agent ID（自律型 Step 2a）にする。
# OBO（/obo-chat の get_my_profile）には true / false に関わらず Agent ID 構成（下記）が必須。
USE_AGENT_ID_EGRESS=true
# a365 setup all で発行済みの Blueprint / Agent Identity（lab2 と同じ Agent ID を再利用）
BLUEPRINT_APP_ID=
AGENT_IDENTITY_APP_ID=
# Blueprint app のクライアント シークレット。
#   ローカル: ここに直接記入（コミット禁止）。
#   ACA: deploy-aca.ps1 が ACA シークレット（secretref blueprint-secret）として注入する。
BLUEPRINT_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# OBO（ユーザー委任型 / lab5 で追加）
# ---------------------------------------------------------------------------
# /obo-chat が受け入れるユーザートークンの aud。既定では api://<BLUEPRINT_APP_ID>。
# scripts/02_patch-blueprint-as-oauth-api.ps1 が設定した identifierUri に合わせる。
BLUEPRINT_API_AUDIENCE=
# OBO で取得する Microsoft Graph の scope（委任権限 User.Read / User.ReadBasic.All を含む）。
GRAPH_SCOPE=https://graph.microsoft.com/.default

# ACA デプロイ設定（prepare-env.ps1 -Me userNN が受講者ごとに -userNN 化して上書き）
# rg-<Me> / aca-contoso-agent-<Me> は lab2 と同じものを再利用し、obo 版は app 名で区別する。
# app 名は ACA の 32 文字制限に収めるため agent を省いた custom-maf-a365-obo を使う。
ACA_RESOURCE_GROUP=rg-foundryobs-eastus2
ACA_APP_NAME=custom-maf-a365-obo
ACA_ENV_NAME=aca-contoso-agent
