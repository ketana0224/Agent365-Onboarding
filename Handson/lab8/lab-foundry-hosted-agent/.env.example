# agent-custom-MAF-ACA 用 .env（例）
# ローカル実行時は scripts/setup-env.ps1 / .sh が ms-foundry-observability/.env から自動生成します。
# ACA 実行時は deploy-aca.ps1 が同じキーを Container App の環境変数として設定します。

AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
# Foundry プロジェクトが存在する Resource Group（RBAC スコープの探索に使用）
AZURE_RESOURCE_GROUP=
# ACA をデプロイするリージョン
AZURE_LOCATION=eastus2

# 既存 Foundry プロジェクト（ms-foundry-observability でデプロイ）
PROJECT_ENDPOINT=
MODEL_DEPLOYMENT_NAME=
# 任意: エージェント専用モデルを使う場合に上書き（未設定なら MODEL_DEPLOYMENT_NAME）
AGENT_MODEL_DEPLOYMENT_NAME=

# ----- LLM: APIM AI Gateway 経由 (apim-aigateway-eastus2) -----
# OpenAIChatCompletionClient(azure_endpoint=...) には path=openai までを含むベース URL を渡す。
APIM_AOAI_ENDPOINT=https://apim-aigateway-eastus2.azure-api.net/openai
APIM_AOAI_DEPLOYMENT=
APIM_AOAI_API_VERSION=2024-10-21
# APIM が validate-azure-ad-token で検証する audience。既定は cognitiveservices（空でOK）。
APIM_SCOPE=

# 可観測性（OTel トレースを App Insights に送信、任意）
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPLICATIONINSIGHTS_NAME=

# ----- MCP: APIM AI Gateway 経由 (contoso-policy/mcp) -----
# URL は APIM の MCP エンドポイントに向ける。APIM が backend に x-contoso-key を付与して中継。
CONTOSO_MCP_URL=https://apim-aigateway-eastus2.azure-api.net/contoso-policy/mcp
# 既定（空）では APIM_SCOPE と同じ scope を共有。別 audience の場合のみ設定。
MCP_RESOURCE_APP_ID=
MCP_SCOPE=
# APIM 経由化後は通常不要。直接 backend に当てる切り戻し用としてのみ残す。
CONTOSO_MCP_KEY=

# ACA デプロイ設定（任意・既定値あり）
ACA_RESOURCE_GROUP=rg-contoso-agent
ACA_APP_NAME=custom-maf-agent
ACA_ENV_NAME=aca-contoso-agent
