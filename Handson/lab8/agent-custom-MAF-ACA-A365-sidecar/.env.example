# agent-custom-MAF-ACA-A365-sidecar の .env 雛形（B = agent-custom-MAF-ACA-A365 のサイドカー出口版）
# 実際の値は ./scripts/prepare-env.ps1 で既存 extLab2 config / .env から自動生成できます。
# 手で埋める場合は以下を設定してください。

# ── サイドカー（Microsoft Entra SDK for AgentID）─────────────────────────
# テナント ID
TENANT_ID=
# Blueprint(親 SP) の appId（= サイドカーの AzureAd__ClientId）
BLUEPRINT_APP_ID=
# Blueprint のクライアント シークレット（dev 専用。本番は WI / MI に切替）
BLUEPRINT_CLIENT_SECRET=
# Agent Identity の appId（autonomous モードで指定 / agent からも AGENT_CLIENT_ID として参照）
AGENT_CLIENT_ID=

# ── エージェント出口（サイドカー or UAMI 切り戻し）──────────────────────
# true（既定）= 出口トークンをサイドカーから取得。false = B と同じ UAMI 出口に切り戻し。
USE_SIDECAR_EGRESS=true
# サイドカーに設定したダウンストリーム API 名（docker-compose は 'Apim' を設定）
SIDECAR_DOWNSTREAM=Apim
# docker compose 内は http://sidecar:5000。ホスト python から叩く場合は http://localhost:5001。
SIDECAR_URL=http://sidecar:5000

# ── LLM（APIM AI Gateway 経由 / B と同一）────────────────────────────────
APIM_AOAI_ENDPOINT=https://apim-aigateway-eastus2.azure-api.net/openai
APIM_AOAI_DEPLOYMENT=gpt-5.4
APIM_AOAI_API_VERSION=2024-10-21
# 別 audience に切替える場合のみ設定（既定は cognitiveservices）
APIM_SCOPE=
# サイドカーのダウンストリーム BaseUrl（通常は既定のままで可）
APIM_BASE_URL=https://apim-aigateway-eastus2.azure-api.net/

# ── MCP（APIM 経由 / Bearer / B と同一）──────────────────────────────────
CONTOSO_MCP_URL=https://apim-aigateway-eastus2.azure-api.net/contoso-policy/mcp

# ── 可観測性（任意）──────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
