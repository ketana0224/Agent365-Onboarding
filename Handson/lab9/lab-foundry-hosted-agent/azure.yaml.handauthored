# yaml-language-server: $schema=https://raw.githubusercontent.com/Azure/azure-dev/main/schemas/v1.0/azure.yaml.json
name: lab-foundry-hosted-agent
metadata:
  template: lab-foundry-hosted-agent@1.0.0
services:
  custom-maf-agent:
    project: ./src/custom-maf-agent
    host: azure.ai.agent
    language: python
    config:
      startupCommand: "python -m main"
      container:
        resources:
          cpu: "0.5"
          memory: "1Gi"
      # モデル gpt-5.4 は既存のため deployments[] は書かない（新規作成を避ける）。
      # Hosted Agent は --project-id で接続した既存プロジェクトの gpt-5.4 をそのまま使う。
